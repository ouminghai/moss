{
  "name": "@mossxyz/erc",
  "version": "0.1.0",
  "description": "Moss interface layer: compiled ERC standard ABIs and address-free generic adapters",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean --target es2022",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "gen:abis": "wagmi generate"
  },
  "dependencies": {
    "@mossxyz/core": "workspace:*",
    "viem": "^2.54.3"
  },
  "devDependencies": {
    "@wagmi/cli": "^2.10.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "~5.9.0",
    "vitest": "^3.2.6",
    "@mossxyz/simulator": "workspace:*"
  }
}
