{
  "name": "@mossxyz/core",
  "version": "0.1.0",
  "description": "Moss core: semantic types, protocol decorators, Plan model, and the debug_traceCall simulator",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
